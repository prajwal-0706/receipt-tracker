# Copy to .env and fill in your values. .env is gitignored.

# Neon Postgres connection string (with ?sslmode=require)
DATABASE_URL=postgresql://user:password@ep-xxxxx.neon.tech/dbname?sslmode=require

# Backends — "fake" returns stub data, "hf_pipeline" calls the loaded transformers pipeline.
# In Colab we set these to "hf_pipeline" after the models are loaded.
VLM_BACKEND=fake
SLM_BACKEND=fake

# Where uploaded receipt images are written
UPLOAD_DIR=./uploads

# Hugging Face token (Colab only — used to download gated/private models if needed)
HF_TOKEN=

# ngrok auth token (Colab only — keeps tunnels stable across reconnects)
NGROK_TOKEN=
